<script type="text/javascript">
	function showPage(hash, page) {
		/** @type {HTMLCollectionOf<HTMLElement>} */
		const pages = document.getElementsByClassName('page');
		for (const page of pages) {
			page.style.display = 'none';
		}
		page.style.display = 'flex';
		window.location.hash = hash;
	}

	const pages = [
		'server',
		'location',
		'crontasks',
		'steam',
		'psn',
		'retroachievements',
		'steamgriddb',
		'letterboxd',
		'tmdb',
		'bluesky',
		'discord',
		'google',
		'sonarr',
		'subsonic',
		'swarm',
		'kawa',
	];

	/** @type Record<string, { radio: HTMLInputElement, page: HTMLElement }> */
	const pageMap = pages.reduce((acc, cur) => {
		/** @type {HTMLInputElement} */
		const radio = document.getElementById(cur);
		const page = document.getElementById(`page-${cur}`);

		radio.addEventListener('change', () => {
			showPage(cur, page);
		})

		acc[cur] = { radio, page };
		return acc;
	}, {});

	const onHashChange = () => {
		const hash = window.location.hash.replace(/^#/, '');
		if (pageMap[hash] !== undefined) {
			const { radio, page } = pageMap[hash];
			radio.checked = true;
			showPage(hash, page);
		}
	}

	window.addEventListener('hashchange', onHashChange);
	onHashChange();


	// === Device Picker === //
	/** @type HTMLCollectionOf<HTMLElement> */
	const devicePickers = document.getElementsByClassName('device-key-picker');
	for (const pickerContainer of devicePickers) {
		/** @type HTMLSelectElement|undefined */
		const pickerSelect = pickerContainer.getElementsByTagName('select')[0];
		/** @type HTMLSpanElement|undefined */
		const pickerDisplay = pickerContainer.getElementsByClassName('device-key-display')[0];
		const updateText = () => {
			if (pickerDisplay === undefined) return;
			pickerDisplay.innerText = pickerSelect?.value || '';
		};
		updateText();
		pickerSelect?.addEventListener('change', updateText);
	}
</script>
