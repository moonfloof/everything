							<a href="https://developers.google.com/maps/documentation/places/web-service/place-types?hl=en#table-a"
								target="_blank" rel="noopener">
								<strong>
									Place Types documentation {{> svgExternal}}
								</strong>
							</a>, but be sure to only add categories from <em>Table A</em>.
						</p>
						<input type="text" class="right" name="googlePlacesIgnoredCategories"
							id="googlePlacesIgnoredCategories" value="{{config.google.placesApiIgnoredCategories}}"
							placeholder="Ignored Search Categories" />
